# VPS production environment — copy to .env on the server only.
# Never commit .env. Generate strong secrets before first deploy.

# Public hostname (must resolve to this VPS for automatic TLS)
PUBLIC_DOMAIN=directory.example.com
ACME_EMAIL=ops@example.com

# Application
APP_NAME=UK Jamaat Directory
APP_VERSION=0.1.0
ENVIRONMENT=production
API_PREFIX=/v1
PUBLIC_BASE_URL=https://directory.example.com
DOCS_ENABLED=false
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Postgres (used by docker-compose.vps.yml)
POSTGRES_PASSWORD=change-me-to-a-long-random-secret

# Inside the compose network (do not point at localhost on the VPS)
DATABASE_URL=postgresql+asyncpg://directory:change-me-to-a-long-random-secret@postgres:5432/directory

# Redis and Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Object storage (MinIO in compose; swap endpoint/credentials for R2/S3 later)
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=uk-jamaat-directory
S3_ACCESS_KEY_ID=change-me-minio-access-key
S3_SECRET_ACCESS_KEY=change-me-minio-secret-key

# Bulk exports — public origin for export URLs (Caddy proxies /exports/* to MinIO)
# Use your CDN/R2/S3 base URL instead when not serving from compose MinIO.
EXPORT_BASE_URL=https://directory.example.com
EXPORT_S3_PREFIX=exports
EXPORT_ENABLED=false

# HTTP/API behavior
# Include localhost for container healthchecks when TrustedHostMiddleware is enabled.
ALLOWED_HOSTS=directory.example.com,localhost,127.0.0.1
CORS_ORIGINS=https://directory.example.com
# Documents operator intent; enforced by uvicorn --proxy-headers in docker-compose.vps.yml
TRUST_PROXY_HEADERS=true

# Source and extraction (enable when ready)
MYLOCALMASJID_ENABLED=false
MYLOCALMASJID_PUBLICATION_POLICY=unknown
OPENAI_API_KEY=

# Crawl (opt-in; requires object storage)
CRAWL_ENABLED=false
CRAWL_USER_AGENT=UKJamaatDirectoryBot/0.1 (+https://github.com/SilentHacks/uk-jamaat-directory)
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_BYTES=5000000
CRAWL_FEED_INTERVAL_HOURS=24
STANDARD_FEED_PATH=/.well-known/uk-jamaat-directory.json
