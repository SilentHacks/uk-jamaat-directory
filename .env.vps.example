# Application
APP_NAME=UK Jamaat Directory
APP_VERSION=0.1.0
ENVIRONMENT=production
API_PREFIX=/v1
PUBLIC_BASE_URL=https://directory.example.org
DOCS_ENABLED=false
ADMIN_API_KEY=replace-with-a-long-random-secret

# Compose service URLs
DATABASE_URL=postgresql+asyncpg://directory:replace-me@postgres:5432/directory
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Object storage
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=uk-jamaat-directory
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# HTTP/API behavior
ALLOWED_HOSTS=directory.example.org
CORS_ORIGINS=https://directory.example.org
TRUST_PROXY_HEADERS=true

# Source and extraction settings
MYLOCALMASJID_ENABLED=false
MYLOCALMASJID_PUBLICATION_POLICY=unknown
OPENAI_API_KEY=
