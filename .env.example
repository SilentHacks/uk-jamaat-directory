# Application
APP_NAME=UK Jamaat Directory
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/v1
PUBLIC_BASE_URL=http://localhost:8000
DOCS_ENABLED=true
ADMIN_API_KEY=

# Local host workflow
DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory
TEST_DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory_test

# Redis and Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object storage
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=uk-jamaat-directory-local
S3_ACCESS_KEY_ID=directory
S3_SECRET_ACCESS_KEY=directory-secret

# Bulk exports (Phase 10)
EXPORT_BASE_URL=http://localhost:8000
EXPORT_S3_PREFIX=exports
EXPORT_ENABLED=true

# HTTP/API behavior
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
TRUST_PROXY_HEADERS=false

# Source and extraction settings
MYLOCALMASJID_ENABLED=false
MYLOCALMASJID_PUBLICATION_POLICY=unknown
OPENAI_API_KEY=

# Crawl (Phase 9 — opt-in; requires MinIO)
CRAWL_ENABLED=false
CRAWL_USER_AGENT=UKJamaatDirectoryBot/0.1 (+https://github.com/SilentHacks/uk-jamaat-directory)
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_BYTES=5000000
CRAWL_FEED_INTERVAL_HOURS=24
STANDARD_FEED_PATH=/.well-known/uk-jamaat-directory.json
