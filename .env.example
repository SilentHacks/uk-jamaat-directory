# UK Jamaat Directory environment template.
# Copy to .env for local development or VPS production. Never commit .env.
#
# Local dev: use the defaults in the "Local development" section.
# VPS: set ENVIRONMENT=production and fill the "Production VPS" section.

# --- Application ---
APP_NAME=UK Jamaat Directory
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/v1
PUBLIC_BASE_URL=http://localhost:8000
# Full Swagger UI at /internal/docs. Blank = on outside production, off in production.
# INTERNAL_DOCS_ENABLED=
ADMIN_API_KEY=
# Admin dashboard (SSR) login session signing key. Set to a long random secret to
# enable the browser admin UI at /admin; blank disables admin login. The JSON admin
# API (/v1/admin, X-Admin-Key) is unaffected by this setting.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=

# --- Local development ---
# DATABASE_URL targets host port 54324 (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory
TEST_DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory_test
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=uk-jamaat-directory-local
S3_ACCESS_KEY_ID=directory
S3_SECRET_ACCESS_KEY=directory-secret
ALLOWED_HOSTS=localhost,127.0.0.1
# Public read API: '*' is the correct default (credentials are never allowed).
CORS_ORIGINS=*
TRUST_PROXY_HEADERS=false

# Global per-IP rate limit on public API traffic (health checks exempt; <=0 disables).
PUBLIC_RATE_LIMIT=120
PUBLIC_RATE_WINDOW_SECONDS=60

# Error tracking (optional; inert when blank).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# --- Production VPS (uncomment/adjust on the server) ---
# ENVIRONMENT=production
# PUBLIC_DOMAIN=directory.example.com
# ACME_EMAIL=ops@example.com
# PUBLIC_BASE_URL=https://directory.example.com
# Image tag to run (managed by scripts/deploy/deploy.sh; default latest).
# IMAGE_TAG=latest
# ADMIN_API_KEY=change-me-to-a-long-random-secret
# SESSION_SECRET_KEY=change-me-to-a-long-random-secret-for-admin-ui-sessions
# POSTGRES_PASSWORD=change-me-to-a-long-random-secret
# DATABASE_URL=postgresql+asyncpg://directory:change-me-to-a-long-random-secret@postgres:5432/directory
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2
# S3_ENDPOINT_URL=http://minio:9000
# S3_BUCKET=uk-jamaat-directory
# S3_ACCESS_KEY_ID=change-me-minio-access-key
# S3_SECRET_ACCESS_KEY=change-me-minio-secret-key
# EXPORT_BASE_URL=https://directory.example.com
# ALLOWED_HOSTS=directory.example.com,localhost,127.0.0.1
# CORS_ORIGINS=*
# TRUST_PROXY_HEADERS=true
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# --- Shared settings ---
S3_REGION=us-east-1

# Bulk exports (Phase 10 — opt-in; requires object storage and a public origin)
# EXPORT_BASE_URL must point at the bucket/CDN that serves export objects.
# EXPORT_BASE_URL=http://localhost:9000/uk-jamaat-directory-local
EXPORT_S3_PREFIX=exports
EXPORT_ENABLED=false

# Source and extraction
MYLOCALMASJID_ENABLED=false
MYLOCALMASJID_PUBLICATION_POLICY=unknown
MUSLIMSINBRITAIN_ENABLED=false
# ADR 0011 (2026-06-06): MiB is now public_redistribution_allowed by default.
# Set to "unknown" if you prefer the conservative read-only posture.
MUSLIMSINBRITAIN_PUBLICATION_POLICY=public_redistribution_allowed
MIB_REPORT_STALE_DAYS=30
# Policy for auto-registered mosque_website crawl sources (register-crawl-sources).
# Conservative "unknown" by default; set to public_redistribution_allowed to publish
# prayer times scraped from mosques' own public websites.
MOSQUE_WEBSITE_PUBLICATION_POLICY=unknown
OPENAI_API_KEY=

# Overnight authoring agent (orchestrate-authoring)
# Backend CLI: opencode (default) or claude_code (Claude Code headless mode).
AI_AGENT_BACKEND=opencode
# Blank = backend default model (opencode: opencode-go/deepseek-v4-flash;
# claude_code: claude-haiku-4-5-20251001).
# AI_AGENT_MODEL=
# AI_AGENT_NAME=        # agent to select via --agent (e.g. "default" or "build")
# AI_AGENT_API_KEY=     # exported as OPENAI_API_KEY / ANTHROPIC_API_KEY per backend
# AI_AGENT_BASE_URL=    # exported as OPENAI_BASE_URL / ANTHROPIC_BASE_URL per backend

# Crawl (Phase 9 — opt-in; requires MinIO)
CRAWL_ENABLED=false
CRAWL_USER_AGENT=UKJamaatDirectoryBot/0.1 (+https://github.com/SilentHacks/uk-jamaat-directory)
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_BYTES=5000000
CRAWL_INTERVAL_HOURS=24

# OSM Overpass export
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_OVERPASS_TIMEOUT_SECONDS=180
