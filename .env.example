# UK Jamaat Directory environment template.
# Copy to .env for local development or VPS production. Never commit .env.
#
# Local dev: use the defaults in the "Local development" section.
# VPS: set ENVIRONMENT=production and fill the "Production VPS" section.

# --- Application ---
APP_NAME=UK Jamaat Directory
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/v1
PUBLIC_BASE_URL=http://localhost:8000
DOCS_ENABLED=true
ADMIN_API_KEY=

# --- Local development ---
# DATABASE_URL targets host port 54324 (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory
TEST_DATABASE_URL=postgresql+asyncpg://directory:directory@localhost:54324/directory_test
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=uk-jamaat-directory-local
S3_ACCESS_KEY_ID=directory
S3_SECRET_ACCESS_KEY=directory-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
TRUST_PROXY_HEADERS=false

# --- Production VPS (uncomment/adjust on the server) ---
# ENVIRONMENT=production
# PUBLIC_DOMAIN=directory.example.com
# ACME_EMAIL=ops@example.com
# PUBLIC_BASE_URL=https://directory.example.com
# DOCS_ENABLED=false
# ADMIN_API_KEY=change-me-to-a-long-random-secret
# POSTGRES_PASSWORD=change-me-to-a-long-random-secret
# DATABASE_URL=postgresql+asyncpg://directory:change-me-to-a-long-random-secret@postgres:5432/directory
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2
# S3_ENDPOINT_URL=http://minio:9000
# S3_BUCKET=uk-jamaat-directory
# S3_ACCESS_KEY_ID=change-me-minio-access-key
# S3_SECRET_ACCESS_KEY=change-me-minio-secret-key
# EXPORT_BASE_URL=https://directory.example.com
# ALLOWED_HOSTS=directory.example.com,localhost,127.0.0.1
# CORS_ORIGINS=https://directory.example.com
# TRUST_PROXY_HEADERS=true

# --- Shared settings ---
S3_REGION=us-east-1

# Bulk exports (Phase 10 — opt-in; requires object storage and a public origin)
# EXPORT_BASE_URL must point at the bucket/CDN that serves export objects.
# EXPORT_BASE_URL=http://localhost:9000/uk-jamaat-directory-local
EXPORT_S3_PREFIX=exports
EXPORT_ENABLED=false

# Source and extraction
MYLOCALMASJID_ENABLED=false
MYLOCALMASJID_PUBLICATION_POLICY=unknown
MUSLIMSINBRITAIN_ENABLED=false
# ADR 0011 (2026-06-06): MiB is now public_redistribution_allowed by default.
# Set to "unknown" if you prefer the conservative read-only posture.
MUSLIMSINBRITAIN_PUBLICATION_POLICY=public_redistribution_allowed
MIB_REPORT_STALE_DAYS=30
OPENAI_API_KEY=

# Crawl (Phase 9 — opt-in; requires MinIO)
CRAWL_ENABLED=false
CRAWL_USER_AGENT=UKJamaatDirectoryBot/0.1 (+https://github.com/SilentHacks/uk-jamaat-directory)
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_BYTES=5000000
CRAWL_INTERVAL_HOURS=24

# OSM Overpass export
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_OVERPASS_TIMEOUT_SECONDS=180
