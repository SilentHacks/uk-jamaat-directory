# TLS reverse proxy for the Directory API.
# Set PUBLIC_DOMAIN and ACME_EMAIL in .env on the VPS.
#
# Caddy obtains and renews certificates automatically when PUBLIC_DOMAIN
# resolves to this host and ports 80/443 are reachable.

{
	email {$ACME_EMAIL}
}

{$PUBLIC_DOMAIN} {
	encode gzip

	# Public bulk export objects (MinIO path-style: /{bucket}/exports/...)
	handle_path /exports/* {
		rewrite * /{$S3_BUCKET}/exports{path}
		reverse_proxy minio:9000
	}

	reverse_proxy api:8000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	log {
		output stdout
		format console
	}
}
