{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "extractor": {
            "description": "Primary agent with all permissions except skills and subagents",
            "mode": "primary",
            "permission": {
                "read": "allow",
                "edit": "allow",
                "glob": "allow",
                "grep": "allow",
                "list": "allow",
                "bash": "allow",
                "task": "deny",
                "external_directory": "allow",
                "todowrite": "allow",
                "webfetch": "allow",
                "websearch": "allow",
                "lsp": "allow",
                "skill": "deny",
                "question": "allow",
                "doom_loop": "allow"
            }
        }
    }
}
